// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ExperienceGuideStatus {
  PENDING
  COMPLETED
  FAILED
}

model Property {
  id               String           @id @default(cuid())
  code             String           @unique
  name             String
  propertyType     String
  bedroomQuantity  Int
  bathroomQuantity Int
  guestCapacity    Int
  address          Json
  operational      Json
  rules            Json
  amenities        Json
  images           String[]
  host             Json
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  experienceGuide  ExperienceGuide?
  reservations     Reservation[]
}

model ExperienceGuide {
  id           String                @id @default(cuid())
  propertyId   String                @unique
  property     Property              @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  status       ExperienceGuideStatus @default(PENDING)
  content      Json?
  errorMessage String?
  generatedAt  DateTime?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
}

model Reservation {
  id             String   @id @default(cuid())
  propertyId     String
  property       Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  reservationCode String  @unique
  guestName      String
  checkInDate    DateTime
  checkOutDate   DateTime
  guestCount     Int
  cleaningFee    Decimal  @db.Decimal(10, 2)
  currency       String
  status         String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  guestAccessTokens GuestAccessToken[]
  auditEvents    AuditEvent[]

  @@index([propertyId])
}

model GuestAccessToken {
  id            String      @id @default(cuid())
  reservationId String
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  tokenHash     String      @unique
  expiresAt     DateTime
  revokedAt     DateTime?
  createdAt     DateTime    @default(now())
  lastUsedAt    DateTime?

  @@index([reservationId])
  @@index([expiresAt])
}

model AuditEvent {
  id            String       @id @default(cuid())
  propertyId    String
  reservationId String?
  reservation   Reservation? @relation(fields: [reservationId], references: [id], onDelete: SetNull)
  eventType     String
  metadata      Json?
  createdAt     DateTime     @default(now())

  @@index([propertyId])
  @@index([reservationId])
  @@index([eventType])
}
